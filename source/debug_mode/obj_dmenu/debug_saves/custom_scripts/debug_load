function scr_debug_load(arg0)
{
    snd_free_all();
    var keep_inv = false;
    
    if (variable_global_exists("dload_cur_inv") && global.dload_cur_inv == 1)
        keep_inv = true;
    
    var cache_inv = 0;
    var cache_invc = 0;
